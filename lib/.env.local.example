# ════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - Campos SIS
# ════════════════════════════════════════════════════════════
# 1) Copiá este archivo como .env.local
# 2) Reemplazá los valores con los de tu proyecto Supabase
# 3) NUNCA subas .env.local al repo (ya está en .gitignore)
# ════════════════════════════════════════════════════════════

# URL pública del proyecto Supabase (la podés ver en Supabase > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon key (pública, segura para usar desde el browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# Service role key (PRIVADA - solo para Server Actions / Route Handlers)
# ⚠️ NUNCA usar esta key desde el cliente. Tiene poder de admin total sobre la BD.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# URL de tu sitio (para redirects de auth)
# Desarrollo:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Producción (cambiar al hacer deploy):
# NEXT_PUBLIC_SITE_URL=https://camposis.bbnetsystem.com
